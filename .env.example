# Authentication (choose one method)
WEBEX_ACCESS_TOKEN="your_personal_access_token_here"

# OAuth settings
WEBEX_CLIENT_ID="your_integration_client_id"
WEBEX_CLIENT_SECRET="your_integration_client_secret"
WEBEX_REDIRECT_PORT="8765"
WEBEX_REDIRECT_URI="http://localhost:8765/callback"
WEBEX_OAUTH_SCOPES="meeting:schedules_read meeting:recordings_read meeting:transcripts_read spark:people_read"
